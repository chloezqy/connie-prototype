# Connie backend (Langflow) connection.
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit real keys.
#
# These have NO "VITE_" prefix on purpose: they are read only by the Vite dev server
# (vite.config.ts), which proxies /langflow -> Langflow and injects the API key server-side.
# The browser never sees the key.

# Where your Langflow server is running.
LANGFLOW_URL=http://localhost:7860

# Langflow API key (required on Langflow 1.5+).
# Create one in Langflow: Settings -> Langflow API Keys -> Add New. Copy it immediately.
LANGFLOW_API_KEY=sk-replace-with-your-langflow-api-key

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION (Vercel) — set these two as Environment Variables in the Vercel
# project, NOT here. Same names, no VITE_ prefix. The serverless proxy at
# `api/langflow/[...path].ts` reads them; the browser never sees them.
#   LANGFLOW_URL      = https://your-langflow-host   (your always-on Langflow, no trailing slash)
#   LANGFLOW_API_KEY  = the key for that instance
# Locally these live in .env.local (above) for the Vite dev proxy. In prod they
# live in Vercel's dashboard for the serverless proxy. Same variables, two homes.
